#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: bin/release <version>"
  echo "  e.g. bin/release 0.1.0-alpha.1"
  echo "       bin/release 1.0.0"
  exit 1
}

[[ $# -eq 1 ]] || usage

VERSION="${1#v}"   # strip leading 'v' if the user included it
TAG="v${VERSION}"

# Sanity checks
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "Error: working tree has uncommitted changes. Commit or stash them first."
  exit 1
fi

if git rev-parse "$TAG" &>/dev/null; then
  echo "Error: tag $TAG already exists."
  exit 1
fi

echo "$VERSION" > VERSION
git add VERSION
git commit -m "chore(release): bump version to ${TAG}"
git tag "$TAG"

echo ""
echo "Tagged ${TAG}. Push with:"
echo "  git push origin master ${TAG}"
