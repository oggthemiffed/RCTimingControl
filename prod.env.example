# ============================================================================
# RCTimingControl — Production Configuration
#
# Copy this file to `.env` before running:
#   cp prod.env.example .env
#   docker compose -f docker-compose.production.yml up -d
#
# ALL values marked REQUIRED must be set — the compose file will refuse to
# start if they are missing. Generate strong secrets before first deployment
# and never reuse them between environments.
# ============================================================================

# --- Image version -----------------------------------------------------------
# Semantic version tag from https://github.com/oggthemiffed/RCTimingControl/releases
# REQUIRED
RCTIMING_VERSION=v0.1.0

# --- Database ----------------------------------------------------------------
# REQUIRED — use a long random password, e.g.:
#   openssl rand -base64 32
POSTGRES_PASSWORD=

# --- Object storage (MinIO) --------------------------------------------------
# REQUIRED
MINIO_ROOT_USER=rctiming
MINIO_ROOT_PASSWORD=

# Public base URL for storage-served files (club logos, audio clips).
# Set to your server's hostname/IP, e.g. http://192.168.1.50/storage/rctiming
# or https://timing.myclub.org/storage/rctiming if running behind a TLS proxy.
# REQUIRED
STORAGE_PUBLIC_BASE_URL=

# --- Application auth --------------------------------------------------------
# HMAC secret for JWT signing. Must decode to >= 256 bits (32+ bytes).
# Generate with: openssl rand -base64 48
# REQUIRED
JWT_SECRET=

# --- AMB decoder -------------------------------------------------------------
# IP address or hostname of the physical AMB/MyLaps decoder on your venue LAN.
# REQUIRED
DECODER_HOST=
# Port — 5100 for RC-4 text protocol (firmware < 4.5, most clubs)
#        5403 for P3 binary protocol  (firmware >= 4.5)
DECODER_PORT=5100

# --- Forwarder authentication ------------------------------------------------
# Pre-shared token the forwarder uses to authenticate its gRPC stream.
# Generate in the Admin panel after first login: Admin -> Forwarder Token.
# Paste the generated token here, then restart the forwarder service.
# REQUIRED
FORWARDER_API_TOKEN=

# --- Networking --------------------------------------------------------------
# Host port nginx listens on. 80 is standard; change if already in use.
# If you terminate TLS in front of this stack (recommended for internet-facing
# deployments) point your proxy at this port and set HOST_PORT to something
# non-standard like 8080 to avoid conflict.
HOST_PORT=80

# --- Text-to-speech (optional) -----------------------------------------------
# Override to change the default announcement voice.
# Available voices depend on the piper service command in docker-compose.production.yml.
# TTS_DEFAULT_VOICE=en_GB-alan-medium
# TTS_ENABLED=true
