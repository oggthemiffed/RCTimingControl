# ============================================================================
# RCTimingControl — Trial Environment Configuration
#
# Copy this file to `.env` before running:
#   cp .env.example .env
#   docker compose -f docker-compose.ghcr.yml up
#
# Requires Docker Compose v2.1+ (for service_completed_successfully / service_healthy).
#
# WARNING: every value below is a TRIAL DEFAULT. Change all secrets before any
#          real-world or internet-facing deployment.
# ============================================================================

# --- Database -------------------------------------------------------------
POSTGRES_PASSWORD=rctiming_trial          # CHANGE BEFORE PRODUCTION

# --- Object storage (MinIO — used for club logo + audio clip uploads) -----
MINIO_ROOT_USER=minioadmin                # CHANGE BEFORE PRODUCTION
MINIO_ROOT_PASSWORD=minioadmin            # CHANGE BEFORE PRODUCTION

# --- Application auth -----------------------------------------------------
# Base64-encoded HMAC secret for JWT signing (must be >= 256 bits decoded).
JWT_SECRET=dGhpcyBpcyBhIGRldmVsb3BtZW50IHNlY3JldCBrZXkgdGhhdCBtdXN0IGJlIGF0IGxlYXN0IDI1NiBiaXRz   # CHANGE BEFORE PRODUCTION

# --- Networking -----------------------------------------------------------
# Host port nginx listens on. Change if something already uses port 80.
HOST_PORT=80

# --- Forwarder authentication ---------------------------------------------
# Pre-shared token the forwarder uses to authenticate its gRPC stream to the app.
# The demo-seed inserts a matching forwarder_token row, so the trial works out of
# the box. Regenerate via Admin -> Forwarder Token for a real deployment.
FORWARDER_API_TOKEN=DEMO-FORWARDER-TOKEN-CHANGE-BEFORE-PRODUCTION   # CHANGE BEFORE PRODUCTION

# --- GHCR variant only (docker-compose.ghcr.yml) --------------------------
# Semantic version tag of the pre-built images to pull.
# Set this to the release tag you downloaded, e.g. v0.1.1.
# Find the latest release at: https://github.com/oggthemiffed/RCTimingControl/releases
# Required by docker-compose.ghcr.yml — there is no `latest` tag.
RCTIMING_VERSION=v0.1.1

# --- Advanced (optional — defaults shown are trial values) ----------------
# Object storage (MinIO) — override if using an external S3-compatible store.
# STORAGE_ENDPOINT=http://minio:9000
# STORAGE_ACCESS_KEY=minioadmin                # CHANGE BEFORE PRODUCTION
# STORAGE_SECRET_KEY=minioadmin                # CHANGE BEFORE PRODUCTION
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET=rctiming
# STORAGE_PUBLIC_BASE_URL=http://localhost/storage

# Text-to-speech (Piper) — override to use a different TTS provider or voice.
# TTS_ENDPOINT=http://piper:10200
# TTS_DEFAULT_VOICE=en_GB-alan-medium
# TTS_ENABLED=true
# TTS_LOCALES=en-GB
